---
// This is your official root landing page template wrapper
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SONOVA — ENTER ENVIRONMENT</title>
  
  <script src="https://cdn.tailwindcss.com" is:inline></script>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;700&family=Syne:wght=800&display=swap" rel="stylesheet">
  
  <script is:inline>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            display: ['Syne', 'sans-serif'],
            body: ['Space Grotesk', 'sans-serif']
          }
        }
      }
    }
  </script>
</head>
<body class="font-body text-xs bg-black text-white h-screen w-screen overflow-hidden flex flex-col justify-between p-6 md:p-10 relative">
  <div id="warp-bubble-overlay"></div>
  <canvas id="galaxy-bg"></canvas>

  <header class="relative z-10 w-full flex justify-between items-start reveal">
    <div>
      <h1 class="font-display font-[800] tracking-tighter text-lg uppercase leading-none">SONOVA</h1>
      <p class="text-[9px] tracking-[0.4em] uppercase opacity-30 mt-1.5">RETAIL SPECIFICATION V1.0</p>
    </div>
    <span class="text-[9px] tracking-widest opacity-20 uppercase font-mono">SYS_INIT_OK</span>
  </header>

  <main class="relative z-10 self-center text-center flex flex-col items-center justify-center grow">
    <div class="mb-8 reveal">
      <h2 class="font-display text-5xl md:text-8xl tracking-tighter uppercase leading-[0.85] mb-4">
        CORE<br><span class="text-transparent" style="-webkit-text-stroke: 1px rgba(255,255,255,0.35);">INTERFACE</span>
      </h2>
      <p class="max-w-xs mx-auto text-xs opacity-40 leading-relaxed font-light tracking-wide px-4">
        Accessing the modular product catalog environment. High-performance design blueprints calibrated for technical utility.
      </p>
    </div>

    <div class="reveal">
      <a 
        href="/products" 
        id="enterStoreBtn"
        class="inline-block px-10 py-4 bg-white text-black font-bold text-[10px] uppercase tracking-[0.25em] border border-white hover:bg-transparent hover:text-white transition-all duration-500 ease-in-out shadow-lg shadow-white/5 active:scale-95"
      >
        Enter Store
      </a>
    </div>
  </main>

  <footer class="relative z-10 w-full flex flex-col md:flex-row justify-between items-center gap-2 border-t border-white/5 pt-4 opacity-30 font-mono text-[9px] uppercase tracking-widest reveal">
    <span>LOC // SG_SERVER_NODE_01</span>
    <span id="liveTimestamp">COORDINATING CHRONO...</span>
  </footer>

  <div id="crosshair"></div>
</body>
</html>

<script>
  // Handle layout styling asset inclusions
  import '../styles/global.css';

  // ===== GALAXY SYSTEM CANVAS BACKGROUND =====
  const canvas = document.getElementById('galaxy-bg') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d');
  const ch = document.getElementById('crosshair');
  let currentWidth = window.innerWidth;
  let currentHeight = window.innerHeight;

  function resizeCanvas() {
    const dpr = window.devicePixelRatio || 1;
    currentWidth = window.innerWidth;
    currentHeight = window.innerHeight;
    canvas.width = currentWidth * dpr;
    canvas.height = currentHeight * dpr;
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(dpr, dpr);
  }
  window.addEventListener('resize', resizeCanvas);
  resizeCanvas();

  class BackgroundDot {
    x: number; y: number; color: string; size: number;
    speedX: number; speedY: number; twinkleSpeed: number; alpha: number;

    constructor(isTiny = false) {
      this.x = Math.random() * currentWidth;
      this.y = Math.random() * currentHeight;
      const colors = ['#ffffff', '#a2d2ff', '#e8dbff', '#fdf0cd'];
      this.color = colors[Math.floor(Math.random() * colors.length)];
      this.size = isTiny ? Math.random() * 1 + 0.5 : Math.random() * 2.5 + 1;
      this.speedX = (Math.random() - 0.5) * (isTiny ? 0.04 : 0.4);
      this.speedY = (Math.random() - 0.5) * (isTiny ? 0.04 : 0.4);
      this.twinkleSpeed = Math.random() * 0.002 + 0.003;
      this.alpha = Math.random();
    }
    update() {
      this.x += this.speedX; this.y += this.speedY;
      if (this.x < 0) this.x = currentWidth;
      if (this.x > currentWidth) this.x = 0;
      if (this.y < 0) this.y = currentHeight;
      if (this.y > currentHeight) this.y = 0;
      this.alpha += this.twinkleSpeed;
      if (this.alpha >= 1 || this.alpha <= 0.1) this.twinkleSpeed = -this.twinkleSpeed;
    }
    draw() {
      ctx.save();
      ctx.globalAlpha = Math.max(0.1, Math.min(1, this.alpha));
      ctx.shadowBlur = 8; ctx.shadowColor = this.color; ctx.fillStyle = this.color;
      ctx.beginPath(); ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2); ctx.fill();
      ctx.restore();
    }
  }

  const bgDots: BackgroundDot[] = [];
  for (let i = 0; i < 20; i++) bgDots.push(new BackgroundDot(false));
  for (let i = 0; i < 50; i++) bgDots.push(new BackgroundDot(true));

  function animBg() {
    ctx.clearRect(0, 0, currentWidth, currentHeight);
    bgDots.forEach(d => { d.update(); d.draw(); });
    requestAnimationFrame(animBg);
  }
  requestAnimationFrame(animBg);

  // Custom Cursor Interaction
  window.addEventListener('mousemove', e => {
    ch.style.left = (e.clientX - 10) + 'px';
    ch.style.top = (e.clientY - 10) + 'px';
    const hovering = e.target.closest('a, button');
    ch.style.transform = hovering ? 'scale(2.2) rotate(45deg)' : 'scale(1) rotate(0deg)';
  });
  document.addEventListener('contextmenu', e => e.preventDefault());

  // Dynamic Metrics Clock
  function updateClock() {
    const clock = document.getElementById('liveTimestamp');
    if (clock) {
      const now = new Date();
      clock.textContent = `SYS_TIME // ${now.toISOString().replace('T', ' ').substring(0, 19)} UTC`;
    }
  }
  setInterval(updateClock, 1000);
  updateClock();

  // Reveal Animations on mount
  document.querySelectorAll('.reveal').forEach((el, i) => {
    setTimeout(() => el.classList.add('visible'), i * 150);
  });
</script>